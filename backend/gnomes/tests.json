{
  "tests": [
    {
      "name": "Статус без email — ошибка 400",
      "method": "GET",
      "path": "/?action=status",
      "expectedStatus": 400
    },
    {
      "name": "Статус несуществующего пользователя — 404",
      "method": "GET",
      "path": "/?action=status&email=nobody_gnome@example.com",
      "expectedStatus": 404
    },
    {
      "name": "Покупка без авторизации — 401",
      "method": "POST",
      "path": "/?action=buy",
      "body": {"email": "nobody@example.com", "password": "wrong", "card_type": 1},
      "expectedStatus": 401
    },
    {
      "name": "Покупка неверного типа — 400",
      "method": "POST",
      "path": "/?action=buy",
      "body": {"email": "nobody@example.com", "password": "wrong", "card_type": 99},
      "expectedStatus": 400
    }
  ]
}
